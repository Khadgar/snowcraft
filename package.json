{
  "name": "snowcraft",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SnowCraft (1999 Flash game) recreation with Three.js + TypeScript",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.mjs",
    "smoke:interaction": "node scripts/interaction.mjs",
    "smoke:combat": "node scripts/combat.mjs"
  },
  "dependencies": {
    "preact": "^10.29.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/three": "^0.185.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^4.0.0-alpha.13",
    "puppeteer-core": "^25.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.2-alpha.11",
    "vite": "^8.1.3",
    "vitest": "^5.0.0-beta.5"
  }
}
